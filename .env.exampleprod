# ---------------------------------------------------------------------------
# Produkcja pod domeną zunto.pl
# Skopiuj ten plik do `.env` na serwerze produkcyjnym i uzupełnij sekrety.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Docker / Compose
# Reverse proxy (np. Nginx Proxy Manager) powinien kierować ruch HTTPS
# z `https://zunto.pl` na port `APP_PORT` tego hosta.
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=zunto

APP_PORT=8090
VITE_PORT=5174
DB_FORWARD_PORT=5434

NGINX_CONTAINER_NAME=zunto-nginx
PHP_CONTAINER_NAME=zunto-php
POSTGRES_CONTAINER_NAME=zunto-postgres
REDIS_CONTAINER_NAME=zunto-redis
WORKER_CONTAINER_NAME=zunto-worker
SCHEDULER_CONTAINER_NAME=zunto-scheduler
NODE_CONTAINER_NAME=zunto-node

POSTGRES_SHM_SIZE=1gb
POSTGRES_SHARED_BUFFERS=2GB
POSTGRES_EFFECTIVE_CACHE_SIZE=6GB
POSTGRES_WORK_MEM=64MB
POSTGRES_MAINTENANCE_WORK_MEM=512MB

# ---------------------------------------------------------------------------
# Aplikacja
# ---------------------------------------------------------------------------
APP_NAME="Zunto"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://zunto.pl

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Baza danych
# `DB_PORT=5432` to port wewnątrz sieci Dockera.
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=zunto
DB_TEST_DATABASE=zunto_test
DB_USERNAME=zunto
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Host-only cookie dla `zunto.pl`.
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=zunto.pl

# Ustaw dokładny adres reverse proxy, jeśli aplikacja stoi za proxy.
# Przykład: TRUSTED_PROXIES=192.168.88.240
TRUSTED_PROXIES=

# ---------------------------------------------------------------------------
# OAuth — Google / Facebook
# Redirect URI musi być zgodny 1:1 z wpisem u dostawcy.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# ---------------------------------------------------------------------------
# Storage / kolejki / cache
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Poczta wychodząca
# Na produkcji zostaw `smtp` albo podstaw własny działający mailer.
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.twojadomena.pl
MAIL_PORT=587
MAIL_USERNAME=noreply@zunto.pl
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@zunto.pl"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Link aktywacyjny
# ---------------------------------------------------------------------------
AUTH_VERIFICATION_EXPIRE=60
AUTH_VERIFICATION_REDIRECT_PATH=/weryfikacja-email

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=https://zunto.pl
VITE_SHOW_SEED_CREDENTIALS=false

# ---------------------------------------------------------------------------
# AI
# ---------------------------------------------------------------------------
AI_ENABLED=false
OPENAI_API_KEY=
AI_MODERATION_MODEL=omni-moderation-latest
AI_CATEGORY_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=15
