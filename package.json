{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint resources/js --max-warnings=0",
        "cache:clean": "bash scripts/maintenance/clear-local-caches.sh",
        "typecheck": "vue-tsc --noEmit -p tsconfig.json",
        "test:unit": "vitest run",
        "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=.cache/playwright playwright test e2e/api.spec.ts",
        "test:e2e:browser": "PLAYWRIGHT_BROWSERS_PATH=.cache/playwright playwright test --grep-invert 'API smoke'",
        "test:e2e:docker": "docker run --rm --network ogloszenia_default -v \"$PWD\":/work -w /work -e E2E_BASE_URL=http://nginx -e PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 mcr.microsoft.com/playwright:v1.52.0-noble npx playwright test"
    },
    "devDependencies": {
        "@pinia/testing": "^1.0.3",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^26.1.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-typescript": "^14.9.0",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.0.1",
        "eslint": "^9.39.4",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "dependencies": {
        "@primeuix/themes": "^2.0.3",
        "axios": "^1.18.1",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "vue": "^3.5.39",
        "vue-router": "^4.6.4"
    }
}
